# ─── Dragonfly Scanner — Environment Variables ─────────────────────
# Copy these into Railway's Variables panel for your service.

# Email notifications (required for signup emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-sending-email@gmail.com
SMTP_PASS=your-gmail-app-password
NOTIFY_EMAIL=sasha@dopestr.com
FROM_EMAIL=noreply@dragonflybrandny.com

# Admin access to view all signups at /api/signups?key=YOUR_KEY
ADMIN_KEY=change-this-to-a-secret

# Railway sets this automatically
# PORT=3001
